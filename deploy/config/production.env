# Necitlivé nastavení nasazení FilmDB na gawt.dtcloud.cz.
#
# Tenhle soubor je VERZOVANÝ (commitnutý) — v tomhle školním projektu jsme se rozhodli
# bezpečnost zjednodušit: jediné skutečné tajemství je SSH klíč v GitHub secrets
# (SSH_PRIVATE_KEY), kterým se Actions přihlásí na server. Nic víc tu nehledej.
#
# Soubor slouží dvěma věcem zároveň:
#   1) interpolaci proměnných v docker-compose.yml (např. ${HTTP_PORT})
#   2) jako env_file kontejneru `web` (Django čte DJANGO_* z prostředí)

# --- compose ---
# Publikovaný HTTP port na serveru. Když před stackem běží reverzní proxy/traefik,
# nastav třeba 8080 a proxy nasměruj sem.
HTTP_PORT=80

# --- Django runtime ---
DJANGO_DEBUG=0
# Produkční SECRET_KEY. Commitnutý záměrně (viz výše); klidně si vygeneruj vlastní:
#   python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
DJANGO_SECRET_KEY=filmdb-prod-2o9x7c4k1m6q8w3z5r0t2y4u6i8o0p-change-me-if-you-like
DJANGO_ALLOWED_HOSTS=gawt.dtcloud.cz,localhost,127.0.0.1,web
DJANGO_CSRF_TRUSTED_ORIGINS=https://gawt.dtcloud.cz,http://gawt.dtcloud.cz

# Vue SPA servíruje nginx pod /app/, takže odkaz z rozcestníku míří tam (ne na :5173).
VUE_FRONTEND_URL=/app/

# Cesty k datům uvnitř kontejneru (odpovídají volume v docker-compose.yml).
DJANGO_DB_PATH=/data/db/db.sqlite3
DJANGO_STATIC_ROOT=/data/static
DJANGO_MEDIA_ROOT=/data/media
